# Copia este archivo como .env para desarrollo local
# En Render configura estas variables en el dashboard → Environment

# Django
SECRET_KEY=cambia-esto-por-una-clave-segura
DEBUG=False
ALLOWED_HOSTS=tuapp.onrender.com
CSRF_TRUSTED_ORIGINS=https://tuapp.onrender.com

# Base de datos (Render lo configura automáticamente al vincular un PostgreSQL)
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# Cloudinary — formato: cloudinary://api_key:api_secret@cloud_name
# Obtener en cloudinary.com → Dashboard → API Keys
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
